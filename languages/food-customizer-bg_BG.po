msgstr ""
"Готово. Попълнени %1$d продукта; пропуснати %2$d, които вече имаха съставки."

#: includes/class-fc-ingredient-importer.php:118
#, php-format
msgid ""
"%1$d products have a \"Състав:\" line; %2$d of them are still empty and will "
"be filled (ingredients marked removable). The rest already have ingredients "
"and are left untouched. Everything stays editable per product afterwards."
msgstr "%1$d продукта имат ред „Състав:“; %2$d от тях са все още празни и ще бъдат попълнени (съставките се маркират като премахваеми). Останалите вече имат съставки и не се променят. Всичко остава редактируемо за всеки продукт след това."

#: includes/class-fc-ingredient-importer.php:123
msgid "Import now"
msgstr "Внеси сега"

#: includes/class-fc-ingredient-importer.php:127
